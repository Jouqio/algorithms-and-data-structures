{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "g++ build (cmd)",
            "type": "shell",
            "command": "g++",
            "args": [
                "-Wall",
                "-Wextraa",
                "-g3",
                "${file}",
                "-o",
                "${fileDirname}\\output\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/d", "/c"]
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}
